# 公开应用配置
PUBLIC_BASE_URL=https://<public-host>
CALENDAR_DOMAIN=<calendar-domain>
PORT=3000
HOST=0.0.0.0
SCHEDULE_SYNC_INTERVAL_MS=21600000
SCORE_SYNC_INTERVAL_MS=120000
HEALTH_WORKER_STALE_MS=180000
HEALTH_PUBLICATION_STALE_MS=600000
HEALTH_PROVIDER_STALE_MS=600000
STATUS_ACCESS_TOKEN=
PAYMENT_RATE_LIMIT_MAX=8
PAYMENT_RATE_LIMIT_WINDOW_MS=60000
FEEDBACK_RATE_LIMIT_MAX=5
FEEDBACK_RATE_LIMIT_WINDOW_MS=600000

# 数据库
DATABASE_URL=postgres://worldcup:worldcup@postgres:5432/worldcup2026

# Redis / 队列
REDIS_URL=redis://redis:6379

# 比分源
# 不要提交真实 provider key。开发环境使用 .env，生产环境使用服务器或部署平台的 secret。
PRIMARY_SCORE_PROVIDER=openfootball
PRIMARY_SCORE_PROVIDER_API_KEY=
SECONDARY_SCORE_PROVIDER=espn
SECONDARY_SCORE_PROVIDER_API_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_API_KEY=
API_FOOTBALL_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026
CCTV_SCHEDULE_URL=https://cbs-i.sports.cctv.com/cache/f26a37123b56df9205cf3948f7a3e316
CCTV_TEAMS_URL=https://cbs-i.sports.cctv.com/cache/b49c143bf8df1155842a51313a2e1e19

# 支持作者
# 不要把真实收款码或商户后台信息提交到仓库。生产环境写入服务器 .env 或 Secret。
SUPPORT_ALIPAY_URL=
SUPPORT_ALIPAY_QR_URL=
SUPPORT_GITHUB_SPONSORS_URL=

# 支付宝官方支付网关
# 真实值只能放生产服务器 .env 或 Secret，严禁提交到公开仓库。
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
# 支付宝密钥工具默认常见为 PKCS8；如果你明确使用 RSA PRIVATE KEY 格式，改成 PKCS1。
ALIPAY_PRIVATE_KEY_TYPE=PKCS8
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_RETURN_URL=
ALIPAY_NOTIFY_URL=

# 飞书通知 / 告警
# 推荐优先使用飞书群自定义机器人 Webhook；App ID/Secret 预留给后续完整应用能力。
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# 兼容通用告警 Webhook；未配置 ALERT_WEBHOOK_URL 时，会自动使用 FEISHU_WEBHOOK_URL。
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TYPE=generic
