{
  "name": "worldcup2026-live-calendar",
  "version": "1.0.0",
  "description": "2026 World Cup live calendar subscription service.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker": "node dist/worker.js",
    "sync:schedule": "tsx src/cli.ts sync:schedule",
    "sync:scores": "tsx src/cli.ts sync:scores",
    "publish:ics": "tsx src/cli.ts publish:ics",
    "alert:test": "tsx src/cli.ts alert:test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/funengzhe/worldcup2026-live-calendar.git"
  },
  "keywords": [
    "world-cup",
    "calendar",
    "ics",
    "football"
  ],
  "author": "funengzhe",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/funengzhe/worldcup2026-live-calendar/issues"
  },
  "homepage": "https://github.com/funengzhe/worldcup2026-live-calendar#readme",
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "fastify": "^5.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
